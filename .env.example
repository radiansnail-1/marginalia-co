# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Google Books
GOOGLE_BOOKS_API_KEY=

# Embeddings. Any OpenAI-compatible embeddings endpoint can work.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=256
EMBEDDING_MAX_RUNTIME_TEXTS=0

# Optional affiliate templates / IDs.
# Bookshop.org: just set the numeric affiliate ID — links become
# https://bookshop.org/a/{ID}/{ISBN13} per book.
NEXT_PUBLIC_BOOKSHOP_AFFILIATE_ID=
# Shopee SG: set the numeric affiliate ID — search links are wrapped
# through https://s.shopee.sg/an_redir for proper attribution.
NEXT_PUBLIC_SHOPEE_AFFILIATE_ID=
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=

# Advanced: override the auto-built URL per provider with a full template.
# Supported placeholders: {query}, {encodedQuery}, {title}, {encodedTitle},
# {author}, {encodedAuthor}, {isbn13}
NEXT_PUBLIC_BOOKSHOP_AFFILIATE_TEMPLATE=
NEXT_PUBLIC_SHOPEE_AFFILIATE_TEMPLATE=
NEXT_PUBLIC_LAZADA_AFFILIATE_TEMPLATE=
NEXT_PUBLIC_AMAZON_AFFILIATE_TEMPLATE=
NEXT_PUBLIC_KOBO_AFFILIATE_TEMPLATE=
NEXT_PUBLIC_AUDIBLE_AFFILIATE_TEMPLATE=

# Optional donation link shown on profile.
NEXT_PUBLIC_DONATION_URL=
